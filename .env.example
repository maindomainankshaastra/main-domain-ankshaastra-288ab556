# ─────────────────────────────────────────────────────────────
# Frontend env vars (Vite). All MUST start with VITE_ to be
# exposed to the browser bundle. Set these in the Vercel dashboard
# under Project Settings → Environment Variables.
# Missing values fall back to safe defaults defined in
# src/config/pricing.ts and src/config/business.ts.
# ─────────────────────────────────────────────────────────────

# ── Supabase (frontend — Dashboard → Project Settings → API) ──
# Project URL → VITE_SUPABASE_URL
VITE_SUPABASE_URL=

# anon public key → VITE_SUPABASE_PUBLISHABLE_KEY (safe in browser; RLS applies)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Reference ID → VITE_SUPABASE_PROJECT_ID (General → Reference ID, e.g. ybiodnymjwnmvdwcloxz)
VITE_SUPABASE_PROJECT_ID=

# ── Razorpay ──
VITE_RAZORPAY_KEY_ID=

# ── Business / contact ──
VITE_SUPPORT_PHONE=919667305577
VITE_WHATSAPP_NUMBER=919667305577
VITE_LEAD_WHATSAPP_NUMBER=919667305557
VITE_SUPPORT_EMAIL=social@ankshaastra.com
VITE_CONTACT_EMAIL=contact@ankshaastra.com
VITE_BUSINESS_ADDRESS=India
VITE_API_BASE_URL=

