# service_role secret key — bypasses RLS; used by /api/* only. Never commit or expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ── Other server-only (Vercel dashboard) ──
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
