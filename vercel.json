{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index?route=$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/operations/process-jobs",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  }
}
